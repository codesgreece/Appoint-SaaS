# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Telegram
# For client-side direct notifications (new + completed appointment)
VITE_TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# For Edge Function cron reminders (30 minutes before)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
CRON_SECRET=set-a-random-secret-for-scheduled-calls

# Optional secret to verify incoming Telegram webhooks
TELEGRAM_WEBHOOK_SECRET=set-a-random-secret-for-telegram-webhook
